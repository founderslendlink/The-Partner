# ═══════════════════════════════════════════════════════════════════
# THE PARTNER — Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Provider — at least one is required ───────────────────────
# Anthropic Claude (primary — best quality)
ANTHROPIC_API_KEY=sk-ant-...
# Get from console.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini (free fallback)
GEMINI_API_KEY=
# Get free key at aistudio.google.com — no credit card needed
# Used automatically when Anthropic is unavailable
GEMINI_MODEL=gemini-1.5-flash

# ── OpenAI (embeddings + Whisper) ────────────────────────────────
# Optional — if not set, Gemini embeddings (768-dim) are used instead
OPENAI_API_KEY=sk-...

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_OPERATOR_CHAT_ID=your-chat-id

# ── Discord ──────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_CHANNEL_BRIEFING=channel-id
DISCORD_CHANNEL_ALERTS=channel-id
DISCORD_CHANNEL_APPROVALS=channel-id
DISCORD_CHANNEL_PIPELINE=channel-id
DISCORD_CHANNEL_DEALS_WON=channel-id
DISCORD_CHANNEL_DEALS_LOST=channel-id
DISCORD_CHANNEL_CONTENT=channel-id
DISCORD_CHANNEL_CAMPAIGNS=channel-id
DISCORD_CHANNEL_SOCIAL=channel-id
DISCORD_CHANNEL_REPORTS=channel-id
DISCORD_CHANNEL_REVENUE=channel-id
DISCORD_CHANNEL_METRICS=channel-id
DISCORD_CHANNEL_MEMORY=channel-id
DISCORD_CHANNEL_DECISIONS=channel-id
DISCORD_CHANNEL_INSIGHTS=channel-id
DISCORD_CHANNEL_SYSTEM=channel-id
DISCORD_CHANNEL_ERRORS=channel-id
DISCORD_CHANNEL_AUDIT=channel-id

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
DASHBOARD_URL=http://localhost:3001

# ── Heartbeat Schedules (cron expressions) ────────────────────────
HEARTBEAT_URGENT_CRON=*/5 * * * *
HEARTBEAT_HOURLY_CRON=0 * * * *
HEARTBEAT_DAILY_CRON=0 8 * * *

# ── Alert Thresholds ──────────────────────────────────────────────
HOT_LEAD_CONTACT_THRESHOLD_MINUTES=30
WARM_LEAD_CONTACT_THRESHOLD_MINUTES=240
STALL_THRESHOLD_HOURS=72
ALERT_COOLDOWN_HOURS=4

# ── Queue Worker ──────────────────────────────────────────────────
ACTION_QUEUE_POLL_INTERVAL_MS=10000
ACTION_LOCK_TIMEOUT_SECONDS=30

# ── Briefing ──────────────────────────────────────────────────────
BRIEFING_TIME=08:00

# ── Email (outbound) ─────────────────────────────────────────────
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=hello@yourdomain.com
DEFAULT_FROM_NAME=Your Business Name

# ── SMS via Twilio ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Google Calendar OAuth ─────────────────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials
# Enable Google Calendar API first
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-railway-url.up.railway.app/oauth/google/callback

# ── Social Media ──────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
